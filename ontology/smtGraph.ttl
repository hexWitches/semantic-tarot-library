<deck-sola-busca> a odi:TarotDeck ;
    dcterms:description "The Sola Busca Tarot is the only complete 78-card deck surviving from the 15th century, notable for being the first to feature fully illustrated, scenic Minor Arcana. Attributed to Nicola di Maestro Antonio d’Ancona (c. 1491), the deck replaces traditional iconography with classical heroes and complex hermetic-alchemical symbolism. Now held at the Pinacoteca di Brera, it serves as the foundational precursor to the modern Rider-Waite-Smith system."@en ;
    dcterms:publisher "Unknown" ;
    dcterms:source <https://waitesmith.org/index.php/decks/the-sola-busca-deck/> ;
    smt:hasIllustrator <person-di-maestro-antonio> ;
    odi:hasAuthor <person-di-maestro-antonio> ;
    odi:hasCurrentNumberOfCards "78" ;
    odi:hasDate "1491" ;
    odi:hasName "Sola Busca Tarot" ;
    odi:hasOriginalNumberOfCards "78" ;
    schema:locationCreated <venice> .

