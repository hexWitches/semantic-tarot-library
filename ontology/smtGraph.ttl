smtg:fig-crescent-moon a smt:SymbolicFigure ;
    dcterms:description "Intuition, mystery, and the illumination of the hidden psyche."@en ;
    skos:broader smtg:concept-popess ;
    skos:prefLabel "Crescent Moon" .

smtg:fig-crown-tower a smt:SymbolicFigure ;
    dcterms:description "The ego being stripped of its false authority."@en ;
    skos:broader smtg:concept-the-tower ;
    skos:prefLabel "Falling Crown" .

smtg:fig-lightning-bolt a smt:SymbolicFigure ;
    dcterms:description "Sudden divine intervention or a flash of overwhelming truth."@en ;
    skos:broader smtg:concept-the-tower ;
    skos:prefLabel "Lightning" .

smtg:fig-pillar-jb a smt:SymbolicFigure ;
    dcterms:description "Boaz and Jachin, representing duality and severity/mercy."@en ;
    skos:broader smtg:concept-popess ;
    skos:prefLabel "Jachin and Boaz" ;
    skos:related "fig_pillar_temple, fig_pillar_throne, fig_towers_moon, fig_pillar_law" .

smtg:fig-pillar-law a smt:SymbolicFigure ;
    dcterms:description "The unwavering neutrality of the law, they provide the balance required for the scales of justice."@en ;
    skos:broader smtg:concept-justice ;
    skos:prefLabel "The Pillars of Truth" ;
    skos:related "fig_pillar_throne, fig_pillar_jb, fig_pillar_temple, fig_towers_moon" .

smtg:fig-pillar-temple a smt:SymbolicFigure ;
    dcterms:description "Free-standing columns framing a central religious figure. They represent the structural laws of the Church and the boundary between the congregation and the divine."@en ;
    skos:broader smtg:concept-pope ;
    skos:prefLabel "The Sacred Gateway" ;
    skos:related "fig_pillar_throne, fig_pillar_jb, fig_towers_moon, fig_pillar_law" .

smtg:fig-pillar-throne a smt:SymbolicFigure ;
    dcterms:description "Vertical architectural supports integrated into the imperial seat.They signify the rigid stability of the state and earthly power."@en ;
    skos:broader smtg:concept-emperor ;
    skos:prefLabel "Ducal Throne Pillars" ;
    skos:related "fig_pillar_temple, fig_pillar_jb, fig_towers_moon, fig_pillar_law" .

smtg:fig-scales-justice a smt:SymbolicFigure ;
    dcterms:description "Balance, fairness, and the weighing of truth."@en ;
    skos:broader smtg:concept-justice ;
    skos:prefLabel "Scales of Justice" .

smtg:fig-scepter-popess a smt:SymbolicFigure ;
    dcterms:description "Spirituality, divine connection, and the silent authority of knowledge."@en ;
    skos:broader smtg:concept-popess ;
    skos:prefLabel "Popess' Scepter" ;
    skos:related "fig_scepter_emperor, fig_scepter_pope, fig_scepter_empress" .

smtg:fig-sword-justice a smt:SymbolicFigure ;
    dcterms:description "The power of logic and the cutting away of falsehood."@en ;
    skos:broader smtg:concept-justice ;
    skos:prefLabel "Sword" .

smtg:fig-water-river a smt:SymbolicFigure ;
    dcterms:description "It symbolizes the boundary between the physical and spiritual worlds and the inevitable passage of time and transition."@en ;
    skos:broader smtg:concept-death ;
    skos:prefLabel "The River of Life" ;
    skos:related "fig_water_healing, fig_water_pool, fig_water_alchemical" .

