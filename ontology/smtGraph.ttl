smtg:deck-noblet a odi:TarotDeck ;
    dcterms:description "Produced around 1650 by Jean Noblet, this deck is the earliest known example of the Tarot de Marseille. Preserving the unaltered symbolism of the 17th century, it offers a rare glimpse into the medieval roots of tarot, influenced by Gothic art and traditional European iconography. Divided into Major and Minor Arcana the Noblet deck stands as both a functional divination tool and a vital piece of tarot history."@en ;
    dcterms:isVersionOf smtg:lineage-marseille ;
    dcterms:publisher "Unknown" ;
    dcterms:source <https://gallica.bnf.fr/ark:/12148/btv1b105109641#> ;
    odi:hasAuthor smtg:person-noblet ;
    odi:hasCurrentNumberOfCards "78" ;
    odi:hasDate "1650" ;
    odi:hasName "Tarot Noblet" ;
    odi:hasOriginalNumberOfCards "78" ;
    schema:locationCreated smtg:paris ;
    smt:hasIllustrator smtg:person-noblet .

