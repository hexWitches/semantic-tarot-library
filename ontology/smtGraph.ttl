<deck-rider-waite-smith> a odi:TarotDeck ;
    dcterms:alternativeTitle "Rider-Waite Tarot" ;
    dcterms:description "The Rider-Waite-Smith deck is a foundational 1910 masterpiece of occult art, created by Arthur Edward Waite and artist Pamela Colman Smith. It revolutionized tarot by replacing traditional \"pip\" markers with evocative, full pictorial scenes for all 78 cards, facilitating intuitive interpretation. Today, it remains the world’s most influential deck, with its iconic visual language serving as the primary standard for modern tarot iconography."@en ;
    dcterms:isVersionOf <lineage-rider-waite> ;
    dcterms:publisher "Rider and Company" ;
    dcterms:source <https://collections.vam.ac.uk/search/?page=1&page_size=15&q=rider+waite+smith> ;
