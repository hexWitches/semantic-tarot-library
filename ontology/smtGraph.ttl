smtg: a void:Dataset ;
    dcterms:conformsTo <https://w3id.org/smt-library/ontology> ;
    dcterms:created "2026-03-03"^^xsd:date ;
    dcterms:creator "Miriana Pinto",
        "Sara Roggiani" ;
    dcterms:description "A dataset providing a semantic representation of tarot decks and their constituent cards, aligned with the SMT ontology."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:publisher <https://github.com/hexWitches> ;
    dcterms:title "The SMT Graph"@en ;
    vann:preferredNamespacePrefix "smtg" ;
    void:dataDump <https://w3id.org/smt-library/graph.ttl> ;
    void:vocabulary <https://w3id.org/smt-library/ontology> .

