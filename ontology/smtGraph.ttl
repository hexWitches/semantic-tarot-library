<deck-pierpont-morgan> a odi:TarotDeck ;
    dcterms:alternativeTitle "Colleoni-Baglioni",
        "Visconti-Sforza Tarot" ;
    dcterms:description "Created shortly after 1450, the Visconti-Sforza Tarot is among the oldest surviving decks from the era when tarot was played at court. Today, its remaining cards are housed at the Accademia Carrara and The Morgan Library & Museum. Attributed primarily to Bonifacio Bembo and Francesco Zavattari, the deck features richly dressed noble figures – likely inspired by the Visconti and Sforza courts – set against luminous gold and decorative backgrounds. Three replacement trumps were later painted by Antonio Cicognara."@en ;
    dcterms:isVersionOf <lineage-visconti-sforza> ;
    dcterms:publisher "Francesco Sforza (commissioned by)" ;
    dcterms:source <https://www.themorgan.org/collection/tarot-cards> ;
    smt:hasIllustrator <person-bembo>,
        <person-cicognara>,
        <person-zavattari> ;
