<deck-brambilla> a odi:TarotDeck ;
    dcterms:alternativeTitle "Brera-Brambilla" ;
    dcterms:description "Created in the mid-15th century and attributed to the painter Bonifacio Bembo, the Tarocchi Brambilla is one of the earliest surviving Italian tarot decks. Likely commissioned for the court of Milan under Francesco Sforza, it reflects the artistic culture and heraldic symbolism of the Visconti–Sforza dynasty. Originally composed of 68 cards, only 48 survive today, preserved in the Pinacoteca di Brera in Milan. Hand-painted on pressed cardboard and richly embellished with gold and silver leaf, the cards were crafted as luxury objects rather than printed playing cards."@en ;
    dcterms:isVersionOf <lineage-visconti-sforza> ;
    dcterms:publisher "Francesco Sforza (commissioned by)" ;
    dcterms:source <https://catalogo.beniculturali.it/detail/HistoricOrArtisticProperty/0300097697-0> ;
    smt:hasIllustrator <person-bembo> ;
    odi:hasAuthor <person-bembo> ;
    odi:hasCurrentNumberOfCards "48" ;
    odi:hasDate "1442-1451" ;
    odi:hasName "Tarocchi Brambilla" ;
    odi:hasOriginalNumberOfCards "68" ;
    schema:locationCreated <milan> .

<deck-modrone> a odi:TarotDeck ;
    dcterms:alternativeTitle "Cary-Yale Collection",
        "Visconti Tarot" ;
    dcterms:description "The Visconti deck, commissioned around 1466 by the Visconti family and attributed to Bonifacio Bembo, stands among the oldest surviving tarot decks. Hand-painted and adorned with gold and silver leaf, it was designed as a luxury courtly object rather than for mass production. With 67 surviving cards, the deck reveals the earliest evolution of tarot imagery, including expanded court figures — male and female Knights and Pages – and the rare inclusion of the theological virtues among the trumps (Faith, Hope, Charity)."@en ;
    dcterms:isVersionOf <lineage-visconti-sforza> ;
    dcterms:publisher "Filippo Maria Visconti (commissioned by)" ;
    dcterms:source <https://beinecke.library.yale.edu/collections/highlights/visconti-tarot> ;
    smt:hasIllustrator <person-bembo> ;
    odi:hasAuthor <person-bembo> ;
    odi:hasCurrentNumberOfCards "67" ;
    odi:hasDate "1442-1447" ;
    odi:hasName "Visconti di Modrone" ;
    odi:hasOriginalNumberOfCards "86" ;
    schema:locationCreated <milan> .

