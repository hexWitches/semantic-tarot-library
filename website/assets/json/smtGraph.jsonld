            "dcterms:description": {
                "@language": "en",
                "@value": "The Sola Busca Tarot is the only complete 78-card deck surviving from the 15th century, notable for being the first to feature fully illustrated, scenic Minor Arcana. Attributed to Nicola di Maestro Antonio d’Ancona (c. 1491), the deck replaces traditional iconography with classical heroes and complex hermetic-alchemical symbolism. Now held at the Pinacoteca di Brera, it serves as the foundational precursor to the modern Rider-Waite-Smith system."
            },
            "https://w3id.org/smt-library/ontology#hasIllustrator": {
                "@id": "smtg:person-di-maestro-antonio"
            },
            "location_created": {
                "@id": "smtg:venice"
            },
            "original_card_count": "78",
            "publication_year": "1491",
            "publisher": "Unknown",
            "source_url": {
                "@id": "https://waitesmith.org/index.php/decks/the-sola-busca-deck/"
            },
            "title": "Sola Busca Tarot"
        },
