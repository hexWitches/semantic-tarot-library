        {
            "@id": "smtg:deck-rider-waite-smith",
            "@type": "odi:TarotDeck",
            "alternative_title": "Rider-Waite Tarot",
            "author_id": [
                {
                    "@id": "smtg:person-smith"
                },
                {
                    "@id": "smtg:person-waite"
                }
            ],
            "current_card_count": "78",
            "dcterms:description": {
                "@language": "en",
                "@value": "The Rider-Waite-Smith deck is a foundational 1910 masterpiece of occult art, created by Arthur Edward Waite and artist Pamela Colman Smith. It revolutionized tarot by replacing traditional \"pip\" markers with evocative, full pictorial scenes for all 78 cards, facilitating intuitive interpretation. Today, it remains the world’s most influential deck, with its iconic visual language serving as the primary standard for modern tarot iconography."
            },
            "deck_lineage_id": {
                "@id": "smtg:lineage-rider-waite"
            },
            "https://w3id.org/smt-library/ontology#hasIllustrator": {
                "@id": "smtg:person-smith"
            },
            "location_created": {
                "@id": "smtg:london"
            },
            "original_card_count": "78",
            "publication_year": "1910",
            "publisher": "Rider and Company",
            "source_url": {
                "@id": "https://collections.vam.ac.uk/search/?page=1&page_size=15&q=rider+waite+smith"
            },
            "title": "Rider-Waite-Smith Tarot"
        },
