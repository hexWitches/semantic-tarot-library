        {
            "@id": "smtg:deck-noblet",
            "@type": "odi:TarotDeck",
            "author_id": {
                "@id": "smtg:person-noblet"
            },
            "current_card_count": {
                "@value": "78"
            },
            "dcterms:description": "Produced around 1650 by Jean Noblet, this deck is the earliest known example of the Tarot de Marseille. Preserving the unaltered symbolism of the 17th century, it offers a rare glimpse into the medieval roots of tarot, influenced by Gothic art and traditional European iconography. Divided into Major and Minor Arcana the Noblet deck stands as both a functional divination tool and a vital piece of tarot history.",
            "deck_lineage_id": {
                "@id": "smtg:lineage-marseille"
            },
            "illustrator_id": {
                "@id": "smtg:person-noblet"
            },
            "location_created": {
                "@id": "smtg:paris"
            },
            "original_card_count": {
                "@value": "78"
            },
            "publication_year": {
                "@value": "1650"
            },
            "publisher": {
                "@value": "Unknown"
            },
