        {
            "@id": "smtg:deck-brambilla",
            "@type": "odi:TarotDeck",
            "alternative_title": {
                "@value": "Brera-Brambilla"
            },
            "author_id": {
                "@id": "smtg:person-bembo"
            },
            "current_card_count": {
                "@value": "48"
            },
            "dcterms:description": "Created in the mid-15th century and attributed to the painter Bonifacio Bembo, the Tarocchi Brambilla is one of the earliest surviving Italian tarot decks. Likely commissioned for the court of Milan under Francesco Sforza, it reflects the artistic culture and heraldic symbolism of the Visconti–Sforza dynasty. Originally composed of 68 cards, only 48 survive today, preserved in the Pinacoteca di Brera in Milan. Hand-painted on pressed cardboard and richly embellished with gold and silver leaf, the cards were crafted as luxury objects rather than printed playing cards.",
            "deck_lineage_id": {
                "@id": "smtg:lineage-visconti-sforza"
            },
            "illustrator_id": {
                "@id": "smtg:person-bembo"
            },
            "location_created": {
                "@id": "smtg:milan"
            },
            "original_card_count": {
                "@value": "68"
            },
            "publication_year": {
                "@value": "1442-1451"
            },
            "publisher": {
                "@value": "Francesco Sforza (commissioned by)"
            },
            "source_url": {
                "@id": "https://catalogo.beniculturali.it/detail/HistoricOrArtisticProperty/0300097697-0"
            },
            "title": {
                "@value": "Tarocchi Brambilla"
            }
        },
