        {
            "@id": "smtg:deck-sola-busca",
            "@type": "odi:TarotDeck",
            "author_id": {
                "@id": "smtg:person-di-maestro-antonio"
            },
            "current_card_count": {
                "@value": "78"
            },
            "dcterms:description": "The Sola Busca Tarot is the only complete 78-card deck surviving from the 15th century, notable for being the first to feature fully illustrated, scenic Minor Arcana. Attributed to Nicola di Maestro Antonio d’Ancona (c. 1491), the deck replaces traditional iconography with classical heroes and complex hermetic-alchemical symbolism. Now held at the Pinacoteca di Brera, it serves as the foundational precursor to the modern Rider-Waite-Smith system.",
            "illustrator_id": {
                "@id": "smtg:person-di-maestro-antonio"
            },
            "location_created": {
                "@id": "smtg:venice"
            },
            "original_card_count": {
                "@value": "78"
            },
            "publication_year": {
                "@value": "1491"
            },
            "publisher": {
                "@value": "Unknown"
            },
            "source_url": {
                "@id": "https://waitesmith.org/index.php/decks/the-sola-busca-deck/"
            },
            "title": {
                "@value": "Sola Busca Tarot"
            }
        },
