        {
            "@id": "smtg:deck-modrone",
            "@type": "odi:TarotDeck",
            "alternative_title": [
                {
                    "@value": "Cary-Yale Collection"
                },
                {
                    "@value": "Visconti Tarot"
                }
            ],
            "author_id": {
                "@id": "smtg:person-bembo"
            },
            "current_card_count": {
                "@value": "67"
            },
            "dcterms:description": "The Visconti deck, commissioned around 1466 by the Visconti family and attributed to Bonifacio Bembo, stands among the oldest surviving tarot decks. Hand-painted and adorned with gold and silver leaf, it was designed as a luxury courtly object rather than for mass production. With 67 surviving cards, the deck reveals the earliest evolution of tarot imagery, including expanded court figures — male and female Knights and Pages – and the rare inclusion of the theological virtues among the trumps (Faith, Hope, Charity).",
            "deck_lineage_id": {
                "@id": "smtg:lineage-visconti-sforza"
            },
            "illustrator_id": {
                "@id": "smtg:person-bembo"
            },
            "location_created": {
                "@id": "smtg:milan"
            },
            "original_card_count": {
                "@value": "86"
            },
            "publication_year": {
                "@value": "1442-1447"
            },
            "publisher": {
                "@value": "Filippo Maria Visconti (commissioned by)"
            },
            "source_url": {
                "@id": "https://beinecke.library.yale.edu/collections/highlights/visconti-tarot"
            },
            "title": {
                "@value": "Visconti di Modrone"
            }
        },
