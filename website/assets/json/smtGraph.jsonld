        {
            "@id": "smtg:deck-pierpont-morgan",
            "@type": "odi:TarotDeck",
            "alternative_title": [
                "Colleoni-Baglioni",
                "Visconti-Sforza Tarot"
            ],
            "author_id": [
                {
                    "@id": "smtg:person-bembo"
                },
                {
                    "@id": "smtg:person-zavattari"
                }
            ],
            "current_card_count": "74",
            "dcterms:description": {
                "@language": "en",
                "@value": "Created shortly after 1450, the Visconti-Sforza Tarot is among the oldest surviving decks from the era when tarot was played at court. Today, its remaining cards are housed at the Accademia Carrara and The Morgan Library & Museum. Attributed primarily to Bonifacio Bembo and Francesco Zavattari, the deck features richly dressed noble figures – likely inspired by the Visconti and Sforza courts – set against luminous gold and decorative backgrounds. Three replacement trumps were later painted by Antonio Cicognara."
            },
            "deck_lineage_id": {
                "@id": "smtg:lineage-visconti-sforza"
            },
            "https://w3id.org/smt-library/ontology#hasIllustrator": [
                {
                    "@id": "smtg:person-bembo"
                },
                {
                    "@id": "smtg:person-cicognara"
                },
                {
                    "@id": "smtg:person-zavattari"
                }
            ],
            "location_created": {
                "@id": "smtg:milan"
            },
            "original_card_count": "78",
            "publication_year": "1451",
            "publisher": "Francesco Sforza (commissioned by)",
            "source_url": {
                "@id": "https://www.themorgan.org/collection/tarot-cards"
            },
            "title": "Pierpont-Morgan Bergamo Tarot"
        },
