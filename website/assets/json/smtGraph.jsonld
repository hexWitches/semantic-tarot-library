        {
            "@id": "smtg:deck-modrone",
            "@type": "odi:TarotDeck",
            "alternative_title": [
                "Cary-Yale Collection",
                "Visconti Tarot"
            ],
            "author_id": {
                "@id": "smtg:person-bembo"
            },
            "current_card_count": "67",
            "dcterms:description": {
                "@language": "en",
                "@value": "The Visconti deck, commissioned around 1466 by the Visconti family and attributed to Bonifacio Bembo, stands among the oldest surviving tarot decks. Hand-painted and adorned with gold and silver leaf, it was designed as a luxury courtly object rather than for mass production. With 67 surviving cards, the deck reveals the earliest evolution of tarot imagery, including expanded court figures — male and female Knights and Pages – and the rare inclusion of the theological virtues among the trumps (Faith, Hope, Charity)."
            },
            "deck_lineage_id": {
                "@id": "smtg:lineage-visconti-sforza"
            },
            "https://w3id.org/smt-library/ontology#hasIllustrator": {
                "@id": "smtg:person-bembo"
            },
            "location_created": {
                "@id": "smtg:milan"
            },
            "original_card_count": "86",
            "publication_year": "1442-1447",
            "publisher": "Filippo Maria Visconti (commissioned by)",
            "source_url": {
                "@id": "https://beinecke.library.yale.edu/collections/highlights/visconti-tarot"
            },
            "title": "Visconti di Modrone"
        },
